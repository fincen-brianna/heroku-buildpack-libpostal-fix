#!/bin/bash
set -eo pipefail

BUILD_DIR=$1
CACHE_DIR=$2

mkdir -p "$BUILD_DIR" "$CACHE_DIR"

# ── snappy ────────────────────────────────────────────────────────────────────
echo "-----> Building snappy"

mkdir -p /tmp/lzf_stub
cat > /tmp/lzf_stub/lzf.h <<'EOF'
#ifndef LZF_H
#define LZF_H
#include <stddef.h>
unsigned int lzf_compress(const void *const in_data, unsigned int in_len, void *out_data, unsigned int out_len);
unsigned int lzf_decompress(const void *const in_data, unsigned int in_len, void *out_data, unsigned int out_len);
#endif
EOF
export CPATH="/tmp/lzf_stub:${CPATH}"

cd "$CACHE_DIR"
wget -q https://codeload.github.com/google/snappy/tar.gz/1.1.3 -O snappy.tar.gz
tar -zxf snappy.tar.gz
cd snappy-1.1.3
./autogen.sh
./configure --prefix=/app/snappy
make
make install
cd "$CACHE_DIR"

# ── libpostal ─────────────────────────────────────────────────────────────────
echo "-----> Building libpostal"

git clone https://github.com/openvenues/libpostal --depth 1
cd libpostal

./bootstrap.sh

# Fix: libpostal's src/features.h defines _FEATURES_H, shadowing the system
# /usr/include/features.h and leaving __GLIBC_USE undefined, which breaks all
# glibc headers (stdlib.h, stdint.h, etc.) on glibc 2.35+
mv src/features.h src/libpostal_features.h
grep -rl '"features.h"' src/ | xargs sed -i 's|"features.h"|"libpostal_features.h"|g'

# Fix: buildinclude was never set in the original script (CFLAGS="-I" broke configure)
# Fix: cp ~/vendor/include/snappy* doesn't exist; snappy is at /app/snappy/include
LDFLAGS="-L/app/snappy/lib" \
CFLAGS="-I/app/snappy/include" \
PKG_CONFIG_PATH="/app/snappy/lib/pkgconfig" \
  ./configure --prefix=/app/libpostal --datadir="$BUILD_DIR"

cp /app/snappy/include/snappy*.h src/

make
make install

mv /app/snappy /app/libpostal "$BUILD_DIR"
