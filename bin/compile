#!/bin/bash
set -eo pipefail

BUILD_DIR=$1
CACHE_DIR=$2
ENV_DIR=$3

echo "-----> Creating lzf.h stub (snappy test suite only)"
mkdir -p /tmp/lzf_stub
cat > /tmp/lzf_stub/lzf.h <<'EOF'
#ifndef LZF_H
#define LZF_H
#include <stddef.h>
unsigned int lzf_compress(const void *const in_data, unsigned int in_len, void *out_data, unsigned int out_len);
unsigned int lzf_decompress(const void *const in_data, unsigned int in_len, void *out_data, unsigned int out_len);
#endif
EOF
export CPATH="/tmp/lzf_stub:${CPATH}"

echo "-----> Running homelight libpostal compile"
curl -s https://raw.githubusercontent.com/homelight/heroku-buildback-libpostal/master/bin/compile \
  | bash -s "$BUILD_DIR" "$CACHE_DIR" "$ENV_DIR" || {
    echo "-----> BUILD FAILED - dumping config.log"
    find /tmp/codon/tmp/cache/libpostal -name config.log -exec cat {} \; 2>/dev/null || echo "config.log not found"
    exit 1
  }
