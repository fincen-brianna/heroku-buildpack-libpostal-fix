#!/bin/bash
set -eo pipefail

BUILD_DIR=$1
CACHE_DIR=$2
ENV_DIR=$3

echo "-----> Creating lzf.h stub"
mkdir -p /tmp/lzf_stub
cat > /tmp/lzf_stub/lzf.h <<'EOF'
#ifndef LZF_H
#define LZF_H
#include <stddef.h>
unsigned int lzf_compress(const void *const in_data, unsigned int in_len, void *out_data, unsigned int out_len);
unsigned int lzf_decompress(const void *const in_data, unsigned int in_len, void *out_data, unsigned int out_len);
#endif
EOF
export CPATH="/tmp/lzf_stub:${CPATH}"

echo "-----> Fetching and patching homelight compile script"
curl -sf https://raw.githubusercontent.com/homelight/heroku-buildback-libpostal/master/bin/compile \
  -o /tmp/hl_compile.sh

echo "-----> Script variable assignments (pre-patch):"
grep -n 'build=' /tmp/hl_compile.sh

# Change the root build path from /app/vendor to /app/snappy
sed -i 's|build=/app/vendor|build=/app/snappy|g' /tmp/hl_compile.sh
# Also fix buildinclude if it's derived separately
sed -i 's|buildinclude=/app/vendor|buildinclude=/app/snappy|g' /tmp/hl_compile.sh

echo "-----> Script variable assignments (post-patch):"
grep -n 'build=' /tmp/hl_compile.sh

echo "-----> Running patched compile"
bash /tmp/hl_compile.sh "$BUILD_DIR" "$CACHE_DIR" "$ENV_DIR"
