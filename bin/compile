#!/bin/bash
set -eo pipefail

BUILD_DIR=$1
CACHE_DIR=$2
ENV_DIR=$3

echo "-----> Creating lzf.h stub"
mkdir -p /tmp/lzf_stub
cat > /tmp/lzf_stub/lzf.h <<'EOF'
#ifndef LZF_H
#define LZF_H
#include <stddef.h>
unsigned int lzf_compress(const void *const in_data, unsigned int in_len, void *out_data, unsigned int out_len);
unsigned int lzf_decompress(const void *const in_data, unsigned int in_len, void *out_data, unsigned int out_len);
#endif
EOF
export CPATH="/tmp/lzf_stub:${CPATH}"
export buildinclude=/app/snappy/include

echo "-----> Fetching and patching homelight compile script"
curl -sf https://raw.githubusercontent.com/homelight/heroku-buildback-libpostal/master/bin/compile \
  -o /tmp/hl_compile.sh

# Fix 1: $buildinclude was empty, now set above but also patch for safety
# Fix 2: script copies snappy headers from /app/vendor/include but snappy installs to /app/snappy/include
sed -i 's|/app/vendor/include/snappy|/app/snappy/include/snappy|g' /tmp/hl_compile.sh
sed -i 's|/app/vendor/lib/libsnappy|/app/snappy/lib/libsnappy|g' /tmp/hl_compile.sh
sed -i 's|/app/vendor/include|/app/snappy/include|g' /tmp/hl_compile.sh
sed -i 's|/app/vendor/lib|/app/snappy/lib|g' /tmp/hl_compile.sh

echo "-----> Running patched compile"
bash /tmp/hl_compile.sh "$BUILD_DIR" "$CACHE_DIR" "$ENV_DIR"
